datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         String    @default("USER") // "USER" | "ADMIN"
  projects     Project[]
  createdAt    DateTime  @default(now())
}

model Project {
  id              String      @id @default(uuid())
  name            String
  calculationDate DateTime    @default(now())
  status          String      @default("ACTIVE")
  kdvRate         Decimal     @default(20) @db.Decimal(5, 2)
  generalMarkup   Decimal     @default(25) @db.Decimal(5, 2)
  ownerId         String?
  owner           User?       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  workGroups      WorkGroup[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([ownerId])
}

model WorkGroup {
  id          String       @id @default(uuid())
  name        String
  code        String?
  order       Int          @default(0)
  parentId    String?
  parent      WorkGroup?   @relation("GroupHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    WorkGroup[]  @relation("GroupHierarchy")
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectPozs ProjectPoz[]
  createdAt   DateTime     @default(now())
}

model PozLibrary {
  id              String         @id @default(uuid())
  pozNo           String
  description     String
  unit            String
  unitPrice       Decimal        @db.Decimal(18, 4)
  year            String
  institutionName String
  fascicleName    String?
  analyses        AnalysisItem[] @relation("ParentPoz")
  usedInAnalyses  AnalysisItem[] @relation("ChildPoz")

  @@unique([pozNo, year, institutionName])
  @@index([pozNo])
  @@index([institutionName, year])
}

model ProjectPoz {
  id            String       @id @default(uuid())
  pozNo         String
  description   String
  unit          String
  quantity      Decimal      @default(0) @db.Decimal(18, 4)
  unitPrice     Decimal      @db.Decimal(18, 4)
  customPrice   Decimal?     @db.Decimal(18, 4)
  markupPercent Decimal      @default(25.0) @db.Decimal(5, 2)
  order         Int          @default(0)
  workGroupId   String
  workGroup     WorkGroup    @relation(fields: [workGroupId], references: [id], onDelete: Cascade)
  metrajRows    MetrajRow[]
  demirajRows   DemirajRow[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model MetrajRow {
  id           String     @id @default(uuid())
  projectPozId String
  projectPoz   ProjectPoz @relation(fields: [projectPozId], references: [id], onDelete: Cascade)
  description  String
  adet         Decimal    @default(1) @db.Decimal(18, 4)
  en           Decimal    @default(1) @db.Decimal(18, 4)
  boy          Decimal    @default(1) @db.Decimal(18, 4)
  yukseklik    Decimal    @default(1) @db.Decimal(18, 4)
  computedQty  Decimal    @db.Decimal(18, 4)
  order        Int        @default(0)
  createdAt    DateTime   @default(now())
}

model DemirajRow {
  id             String     @id @default(uuid())
  projectPozId   String
  projectPoz     ProjectPoz @relation(fields: [projectPozId], references: [id], onDelete: Cascade)
  description    String
  cap            Int
  uzunluk        Decimal    @db.Decimal(18, 4)
  adet           Decimal    @db.Decimal(18, 4)
  weightPerMeter Decimal    @db.Decimal(18, 6)
  computedKg     Decimal    @db.Decimal(18, 4)
  order          Int        @default(0)
  createdAt      DateTime   @default(now())
}

model AnalysisItem {
  id             String     @id @default(uuid())
  parentPozId    String
  parentPoz      PozLibrary @relation("ParentPoz", fields: [parentPozId], references: [id], onDelete: Cascade)
  childPozId     String
  childPoz       PozLibrary @relation("ChildPoz", fields: [childPozId], references: [id], onDelete: Cascade)
  quantityFactor Decimal    @db.Decimal(18, 6)
  unit           String
  order          Int        @default(0)
}

// Kullanıcı işlem geçmişi (audit log) — denormalize edilmiş ki kayıt silinse bile log kalır
model ActivityLog {
  id            String   @id @default(uuid())
  projectId     String?
  projectName   String
  workGroupName String?
  pozNo         String?
  action        String   // örn: "İş kalemi eklendi", "Miktar değişti: 79", "İş kalemi silindi"
  userName      String
  createdAt     DateTime @default(now())

  @@index([createdAt])
}
